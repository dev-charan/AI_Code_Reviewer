# Copy this file to backend/.env and fill in your values

# Required — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — needed only for private GitHub repos or to avoid rate limits
# Generate at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here
